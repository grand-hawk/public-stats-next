{
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [3000],
  "containerEnv": {
    "DATA_ENV": "production",
    "FORCE_CACHE": "true",
    "NEXT_PUBLIC_STACKBLITZ": "true",
    "NODE_ENV": "development"
  },
  "postCreateCommand": "pnpm install --no-lockfile --ignore-scripts && pnpm generate && pnpm content:generate",
  "remoteUser": "node"
}
